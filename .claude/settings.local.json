{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format --quiet $CLAUDE_FILE_PATH 2>/dev/null; ruff check --fix --quiet $CLAUDE_FILE_PATH 2>/dev/null; true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python -m pytest:*)",
      "Bash(python -c:*)",
      "Bash(python src/*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(mypy:*)",
      "Bash(streamlit run:*)",
      "Bash(jupyter:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(rm _gen*)",
      "Bash(rm _test*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(pip install:*)",
      "Bash(pip uninstall:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- :*)"
    ]
  }
}
